' ==============================================================================
' 5. 状态机图 (State Machine)
' ==============================================================================

@startuml RootPassGen-StateMachine

title Lease & Password Lifecycle State Machine

skinparam state {
    BackgroundColor<<active>> #C8E6C9
    BackgroundColor<<processing>> #FFF9C4
    BackgroundColor<<error>> #FFCDD2
}

[*] --> CONFIG_LOADED : Initialize

state CONFIG_LOADED {
    [*] --> ReadConfig
    ReadConfig --> WriteKV : Config parsed
}

state WriteKV {
    [*] --> StoreInEtcd
    StoreInEtcd --> [*] : Success
}

CONFIG_LOADED --> ACTIVE_LEASE : Write to etcd

state ACTIVE_LEASE <<active>> {
    [*] -> Watching
    Watching -> [*] : Delete Event
}

ACTIVE_LEASE --> WATCH_MONITOR : Watch triggered

state WATCH_MONITOR {
    [*] -> MonitorEvents
    MonitorEvents -> DeleteDetected : TTL expires
}

WATCH_MONITOR --> QUEUED : Publish to MQ

state QUEUED <<processing>> {
    [*] -> InQueue
    InQueue -> Consumed : XReadGroup
}

QUEUED --> PROCESSING : Consumer reads

state PROCESSING <<processing>> {
    [*] -> GeneratePass
    GeneratePass -> GetConfig : New password
    GetConfig -> StorePass : Config loaded
    StorePass -> SSHExecute : Password stored
}

PROCESSING --> SSH_EXECUTING : Execute SSH

state SSH_EXECUTING <<processing>> {
    [*] -> Connecting
    Connecting -> Executing : Connected
    Executing -> [*] : Result
}

SSH_EXECUTING --> SUCCESS : Password changed
SSH_EXECUTING --> FAILED : SSH error

state SUCCESS {
    [*] -> UpdatePassword
    UpdatePassword -> [*] : Done
}

state FAILED <<error>> {
    [*] -> RestorePassword
    RestorePassword -> [*] : Rollback
}

SUCCESS --> ACTIVE_LEASE : Recreate Lease
FAILED --> ACTIVE_LEASE : Recreate Lease

note right of ACTIVE_LEASE
    TTL: 30 seconds
    Key: <server>/lease
end note

note right of PROCESSING
    • GenPassword()
    • Get config from etcd
    • Store new password
end note

note right of SSH_EXECUTING
    • SSH connect
    • Execute passwd
    • Return result
end note

@enduml

' ==============================================================================
' 6. 数据流图 (Data Flow Diagram)
' ==============================================================================

@startuml RootPassGen-DFD

title RootPassGen 数据流图 (Level 1)

!define PROCESS #E3F2FD
!define STORE #FFF3E0
!define TERMINATOR #F3E5F5

rectangle "System" {
    component "Config Manager" as config_mgr PROCESS
    component "Storage Manager" as storage_mgr PROCESS
    component "Watch Manager" as watch_mgr PROCESS
    component "MQ Producer" as mq_prod PROCESS
    component "MQ Consumers" as mq_cons PROCESS
    component "Password Manager" as pass_mgr PROCESS
    component "SSH Executor" as ssh_exec PROCESS
}

database "etcd" as etcd STORE
database "Redis" as redis STORE
file "config.yaml" as config_file TERMINATOR
cloud "Target Servers" as targets TERMINATOR

' Flow
config_file --> config_mgr : YAML Config
config_mgr --> storage_mgr : Config Struct
storage_mgr --> etcd : KV Write
etcd --> storage_mgr : Config Read
storage_mgr --> watch_mgr : Lease Creation
etcd --> watch_mgr : Delete Events
watch_mgr --> mq_prod : Event Message
mq_prod --> redis : XAdd
redis --> mq_cons : XReadGroup
mq_cons --> pass_mgr : Process Key
etcd --> mq_cons : Config Data
mq_cons --> pass_mgr : Config
pass_mgr --> etcd : New Password
pass_mgr --> ssh_exec : New Password + Config
ssh_exec --> targets : SSH passwd cmd

@enduml

